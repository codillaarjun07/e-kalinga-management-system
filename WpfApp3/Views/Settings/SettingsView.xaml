<UserControl x:Class="WpfApp3.Views.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WpfApp3.ViewModels.Settings"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1440"
            >

    <UserControl.DataContext>
        <vm:SettingsViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="170"/>
            <Setter Property="Padding" Value="22,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Foreground" Value="#2E3A59"/>
            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="76"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#E5484D"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="160"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Foreground" Value="#5F6F8F"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="22"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F7F9FC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconTextButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Foreground" Value="#2E3A59"/>
            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabButtonDepartments" TargetType="Button" BasedOn="{StaticResource TabButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedTab}" Value="Departments">
                    <Setter Property="Background" Value="#4F46E5"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabButtonFunds" TargetType="Button" BasedOn="{StaticResource TabButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedTab}" Value="Source of Fund">
                    <Setter Property="Background" Value="#4F46E5"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabButtonClassifications" TargetType="Button" BasedOn="{StaticResource TabButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedTab}" Value="Classifications">
                    <Setter Property="Background" Value="#4F46E5"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabButtonRoles" TargetType="Button" BasedOn="{StaticResource TabButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedTab}" Value="Roles">
                    <Setter Property="Background" Value="#4F46E5"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchBoxText" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2E3A59"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Foreground" Value="#7C8AA5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#EEF2FF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="14,0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#EEF2FF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAFBFF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid >
        <Border
                Background="White"
                CornerRadius="24"
                Padding="28">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- tabs -->
                <Border Background="#F5F7FB"
        CornerRadius="24"
        Padding="6"
        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Departments"
                Style="{StaticResource TabButtonDepartments}"
                Command="{Binding SelectTabCommand}"
                CommandParameter="Departments"/>

                        <Button Content="Source of Fund"
                Style="{StaticResource TabButtonFunds}"
                Command="{Binding SelectTabCommand}"
                CommandParameter="Source of Fund"/>

                        <Button Content="Classifications"
                Style="{StaticResource TabButtonClassifications}"
                Command="{Binding SelectTabCommand}"
                CommandParameter="Classifications"/>

                        <Button Content="Roles"
                Style="{StaticResource TabButtonRoles}"
                Command="{Binding SelectTabCommand}"
                CommandParameter="Roles"
                Margin="0"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2">

                    <!-- DEPARTMENTS -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTab}" Value="Departments">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="420"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Height="46"
                                    Background="#F8FAFD"
                                    BorderBrush="#EEF2FF"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="16,0">
                                <Grid>
                                    <TextBox Text="{Binding DepartmentSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SearchBoxText}"/>
                                    <TextBlock Text="Search department"
                                               Foreground="#A3AEC2"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DepartmentSearchText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <Button Grid.Column="2"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding AddDepartmentCommand}"
                                    Content="Add Department"
                                    Margin="16,0,0,0"/>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Department Options"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#2E3A59"
                                       VerticalAlignment="Center"/>

                            <Border Grid.Column="1"
                                    Background="#F5F7FB"
                                    CornerRadius="14"
                                    Padding="12,6"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding DepartmentFoundText}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#6B778C"/>
                            </Border>
                        </Grid>

                        <Border Grid.Row="4"
                                Background="White"
                                BorderBrush="#EEF2FF"
                                BorderThickness="1"
                                CornerRadius="20"
                                Padding="10">
                            <DataGrid ItemsSource="{Binding DepartmentItems}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      SelectionUnit="FullRow"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      RowHeaderWidth="0"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Foreground="#2E3A59"
                                      FontSize="13"
                                      ColumnHeaderHeight="44"
                                      RowHeight="44">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID"
                                                        Binding="{Binding Id}"
                                                        Width="80"/>

                                    <DataGridTextColumn Header="Department"
                                                        Binding="{Binding Name}"
                                                        Width="*"/>

                                    <DataGridTemplateColumn Header="Status" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Height="28"
                                                        MinWidth="68"
                                                        Padding="12,0"
                                                        CornerRadius="14"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FDECEC"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Background" Value="#EAF7EE"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>

                                                    <TextBlock VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               FontSize="12"
                                                               FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Inactive"/>
                                                                <Setter Property="Foreground" Value="#C43D3D"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Text" Value="Active"/>
                                                                        <Setter Property="Foreground" Value="#2F8F57"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Actions" Width="200">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Left">
                                                    <Button Content="Edit"
                                                            Style="{StaticResource IconTextButton}"
                                                            Command="{Binding DataContext.EditDepartmentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"/>

                                                    <Button Content="Delete"
                                                            Style="{StaticResource DangerButton}"
                                                            Command="{Binding DataContext.DeleteDepartmentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>

                    <!-- SOURCE OF FUND -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTab}" Value="Source of Fund">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="420"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Height="46"
                                    Background="#F8FAFD"
                                    BorderBrush="#EEF2FF"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="16,0">
                                <Grid>
                                    <TextBox Text="{Binding FundSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SearchBoxText}"/>
                                    <TextBlock Text="Search source of fund"
                                               Foreground="#A3AEC2"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FundSearchText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <Button Grid.Column="2"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding AddFundCommand}"
                                    Content="Add Source of Fund"
                                    Margin="16,0,0,0"/>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Source of Fund Options"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#2E3A59"
                                       VerticalAlignment="Center"/>

                            <Border Grid.Column="1"
                                    Background="#F5F7FB"
                                    CornerRadius="14"
                                    Padding="12,6"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding FundFoundText}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#6B778C"/>
                            </Border>
                        </Grid>

                        <Border Grid.Row="4"
                                Background="White"
                                BorderBrush="#EEF2FF"
                                BorderThickness="1"
                                CornerRadius="20"
                                Padding="10">
                            <DataGrid ItemsSource="{Binding FundItems}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      SelectionUnit="FullRow"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      RowHeaderWidth="0"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Foreground="#2E3A59"
                                      FontSize="13"
                                      ColumnHeaderHeight="44"
                                      RowHeight="44">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID"
                                                        Binding="{Binding Id}"
                                                        Width="80"/>

                                    <DataGridTextColumn Header="Source of Fund"
                                                        Binding="{Binding Name}"
                                                        Width="*"/>

                                    <DataGridTemplateColumn Header="Status" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Height="28"
                                                        MinWidth="68"
                                                        Padding="12,0"
                                                        CornerRadius="14"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FDECEC"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Background" Value="#EAF7EE"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>

                                                    <TextBlock VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               FontSize="12"
                                                               FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Inactive"/>
                                                                <Setter Property="Foreground" Value="#C43D3D"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Text" Value="Active"/>
                                                                        <Setter Property="Foreground" Value="#2F8F57"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Actions" Width="200">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Left">
                                                    <Button Content="Edit"
                                                            Style="{StaticResource IconTextButton}"
                                                            Command="{Binding DataContext.EditFundCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"/>

                                                    <Button Content="Delete"
                                                            Style="{StaticResource DangerButton}"
                                                            Command="{Binding DataContext.DeleteFundCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>

                    <!-- CLASSIFICATIONS -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTab}" Value="Classifications">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="420"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Height="46"
                                    Background="#F8FAFD"
                                    BorderBrush="#EEF2FF"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="16,0">
                                <Grid>
                                    <TextBox Text="{Binding ClassificationSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SearchBoxText}"/>
                                    <TextBlock Text="Search classification"
                                               Foreground="#A3AEC2"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ClassificationSearchText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <Button Grid.Column="2"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding AddClassificationCommand}"
                                    Content="Add Classification"
                                    Margin="16,0,0,0"/>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Classification Options"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#2E3A59"
                                       VerticalAlignment="Center"/>

                            <Border Grid.Column="1"
                                    Background="#F5F7FB"
                                    CornerRadius="14"
                                    Padding="12,6"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding ClassificationFoundText}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#6B778C"/>
                            </Border>
                        </Grid>

                        <Border Grid.Row="4"
                                Background="White"
                                BorderBrush="#EEF2FF"
                                BorderThickness="1"
                                CornerRadius="20"
                                Padding="10">
                            <DataGrid ItemsSource="{Binding ClassificationItems}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      SelectionUnit="FullRow"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      RowHeaderWidth="0"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Foreground="#2E3A59"
                                      FontSize="13"
                                      ColumnHeaderHeight="44"
                                      RowHeight="44">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID"
                                                        Binding="{Binding Id}"
                                                        Width="80"/>

                                    <DataGridTextColumn Header="Classification"
                                                        Binding="{Binding Name}"
                                                        Width="*"/>

                                    <DataGridTemplateColumn Header="Status" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Height="28"
                                                        MinWidth="68"
                                                        Padding="12,0"
                                                        CornerRadius="14"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FDECEC"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Background" Value="#EAF7EE"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>

                                                    <TextBlock VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               FontSize="12"
                                                               FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Inactive"/>
                                                                <Setter Property="Foreground" Value="#C43D3D"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Text" Value="Active"/>
                                                                        <Setter Property="Foreground" Value="#2F8F57"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Actions" Width="200">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Left">
                                                    <Button Content="Edit"
                                                            Style="{StaticResource IconTextButton}"
                                                            Command="{Binding DataContext.EditClassificationCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"/>

                                                    <Button Content="Delete"
                                                            Style="{StaticResource DangerButton}"
                                                            Command="{Binding DataContext.DeleteClassificationCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>

                    <!-- ROLES -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTab}" Value="Roles">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="420"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Height="46"
                Background="#F8FAFD"
                BorderBrush="#EEF2FF"
                BorderThickness="1"
                CornerRadius="14"
                Padding="16,0">
                                <Grid>
                                    <TextBox Text="{Binding RoleSearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchBoxText}"/>
                                    <TextBlock Text="Search role"
                           Foreground="#A3AEC2"
                           FontSize="13"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RoleSearchText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <Button Grid.Column="2"
                Style="{StaticResource PrimaryButton}"
                Command="{Binding AddRoleCommand}"
                Content="Add Role"
                Margin="16,0,0,0"/>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Role Options"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#2E3A59"
                   VerticalAlignment="Center"/>

                            <Border Grid.Column="1"
                Background="#F5F7FB"
                CornerRadius="14"
                Padding="12,6"
                VerticalAlignment="Center">
                                <TextBlock Text="{Binding RoleFoundText}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#6B778C"/>
                            </Border>
                        </Grid>

                        <Border Grid.Row="4"
            Background="White"
            BorderBrush="#EEF2FF"
            BorderThickness="1"
            CornerRadius="20"
            Padding="10">
                            <DataGrid ItemsSource="{Binding RoleItems}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None"
                  RowHeaderWidth="0"
                  Background="Transparent"
                  BorderThickness="0"
                  Foreground="#2E3A59"
                  FontSize="13"
                  ColumnHeaderHeight="44"
                  RowHeight="44">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="80"/>

                                    <DataGridTextColumn Header="Role"
                                    Binding="{Binding Name}"
                                    Width="*"/>

                                    <DataGridTemplateColumn Header="Status" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Height="28"
                                    MinWidth="68"
                                    Padding="12,0"
                                    CornerRadius="14"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FDECEC"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Background" Value="#EAF7EE"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>

                                                    <TextBlock VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Inactive"/>
                                                                <Setter Property="Foreground" Value="#C43D3D"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Text" Value="Active"/>
                                                                        <Setter Property="Foreground" Value="#2F8F57"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Actions" Width="200">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left">
                                                    <Button Content="Edit"
                                        Style="{StaticResource IconTextButton}"
                                        Command="{Binding DataContext.EditRoleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>

                                                    <Button Content="Delete"
                                        Style="{StaticResource DangerButton}"
                                        Command="{Binding DataContext.DeleteRoleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- FORM MODAL -->
        <Grid Panel.ZIndex="900"
              Visibility="{Binding IsFormOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#80000000"
                    MouseLeftButtonDown="OverlayBackdrop_MouseLeftButtonDown"/>

            <Border Width="520"
                    Padding="22"
                    CornerRadius="18"
                    Background="White"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding FormTitle}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#2E3A59"/>

                        <Button Grid.Column="1"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#2E3A59"
                                FontSize="16"
                                Cursor="Hand"
                                Command="{Binding CloseFormCommand}"
                                Content="✕"/>
                    </Grid>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="Name"
                                   Foreground="#2E3A59"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <Border Background="#F8FAFD"
                                BorderBrush="#EEF2FF"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,8">
                            <TextBox Text="{Binding NameInput, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="#2E3A59"
                                     FontSize="13"/>
                        </Border>

                        <CheckBox Content="Active"
                                  IsChecked="{Binding IsActiveInput}"
                                  Margin="0,16,0,0"
                                  Foreground="#2E3A59"
                                  FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Cancel"
                                Style="{StaticResource GhostButton}"
                                Margin="0,0,10,0"
                                Command="{Binding CloseFormCommand}"/>

                        <Button Content="Save"
                                Style="{StaticResource PrimaryButton}"
                                MinWidth="110"
                                Command="{Binding SaveFormCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- DELETE MODAL -->
        <Grid Panel.ZIndex="901"
              Visibility="{Binding IsDeleteOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#80000000"
                    MouseLeftButtonDown="OverlayBackdrop_MouseLeftButtonDown"/>

            <Border Width="500"
                    Padding="22"
                    CornerRadius="18"
                    Background="White"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Delete Setting"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#2E3A59"/>

                    <TextBlock Grid.Row="2"
                               Text="{Binding DeleteMessage}"
                               TextWrapping="Wrap"
                               Foreground="#6B778C"
                               FontSize="13"/>

                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Cancel"
                                Style="{StaticResource GhostButton}"
                                Margin="0,0,10,0"
                                Command="{Binding CancelDeleteCommand}"/>

                        <Button Content="Delete"
                                Style="{StaticResource DangerButton}"
                                MinWidth="90"
                                Height="44"
                                Padding="18,0"
                                Command="{Binding ConfirmDeleteCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- LOADING OVERLAY -->
        <Grid Panel.ZIndex="950"
              Background="#66FFFFFF"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <Border Width="260"
                    Padding="20"
                    CornerRadius="18"
                    Background="White"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Loading settings..."
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#2E3A59"
                               HorizontalAlignment="Center"/>

                    <ProgressBar IsIndeterminate="True"
                                 Height="8"
                                 Margin="0,16,0,0"
                                 Foreground="#4F46E5"
                                 Background="#E9EEF7"/>

                    <TextBlock Text="Please wait while data is being fetched."
                               FontSize="12"
                               Foreground="#8A94A6"
                               Margin="0,12,0,0"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>