<Window x:Class="WpfApp3.Views.Login.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WpfApp3.ViewModels.Login"
        Title="E-Kalinga Management System"
        Width="420" Height="720"
        MinWidth="420" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F3F5F9"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Icon="/Views/Login/ekaling.png">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="AppBg" Color="#F3F5F9"/>
        <SolidColorBrush x:Key="Primary" Color="#1E3A8A"/>
        <SolidColorBrush x:Key="Text" Color="#111827"/>
        <SolidColorBrush x:Key="Muted" Color="#64748B"/>
        <SolidColorBrush x:Key="Border" Color="#D7DEEA"/>

        <!-- Input wrapper (focus ring + hover) -->
        <Style x:Key="InputChrome" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#BFC9DA"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Primary}"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#1E3A8A" BlurRadius="14" ShadowDepth="0" Opacity="0.18"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.65"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox look (no double border) -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- PasswordBox look (no double border) -->
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Modern primary button (hover/pressed) -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="#2E3A59"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#25304A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Bd" Property="Opacity" Value="0.95"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ✅ Eye Toggle (clean overlay icon + smooth animation; WPF-safe) -->

        <!-- ✅ Eye Toggle (OPEN when checked = show, CLOSED when unchecked = hide) -->
        <Style x:Key="EyeToggle" TargetType="ToggleButton">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        CornerRadius="10"
                        RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>

                            <Viewbox Width="20" Height="20" Stretch="Uniform">
                                <Grid Width="24" Height="24">

                                    <!-- CLOSED EYE (HIDE) -->
                                    <Grid x:Name="IconClosed" Opacity="1">
                                        <!-- eyelid -->
                                        <Path Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"
                                      Data="M4,12 C7.5,16 16.5,16 20,12"/>

                                        <!-- lashes (more visible like your 3rd photo) -->
                                        <Path Stroke="{TemplateBinding Foreground}" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M7.4,11.2 L6.0,9.4"/>
                                        <Path Stroke="{TemplateBinding Foreground}" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M12,10.8 L12,8.8"/>
                                        <Path Stroke="{TemplateBinding Foreground}" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M16.6,11.2 L18.0,9.4"/>
                                    </Grid>

                                    <!-- OPEN EYE (SHOW) -->
                                    <Grid x:Name="IconOpen" Opacity="0">
                                        <!-- eye outline -->
                                        <Path Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"
                                      Data="M2,12
                                            C4.8,7.2 8.6,5 12,5
                                            C15.4,5 19.2,7.2 22,12
                                            C19.2,16.8 15.4,19 12,19
                                            C8.6,19 4.8,16.8 2,12 Z"/>

                                        <!-- pupil -->
                                        <Ellipse Width="6.5" Height="6.5"
                                         Stroke="{TemplateBinding Foreground}"
                                         StrokeThickness="2"
                                         Fill="Transparent"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>

                                        <!-- top lashes -->
                                        <Path Stroke="{TemplateBinding Foreground}" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M7.2,7.2 L6.0,5.6"/>
                                        <Path Stroke="{TemplateBinding Foreground}" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M12,6.6 L12,4.8"/>
                                        <Path Stroke="{TemplateBinding Foreground}" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M16.8,7.2 L18.0,5.6"/>
                                    </Grid>

                                </Grid>
                            </Viewbox>
                        </Border>

                        <ControlTemplate.Triggers>
                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="{StaticResource Primary}"/>
                            </Trigger>

                            <!-- Press -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd"
                                Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                            <!-- ✅ Checked = SHOW password => OPEN eye -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="IconOpen" Property="Opacity" Value="1"/>
                                <Setter TargetName="IconClosed" Property="Opacity" Value="0"/>
                            </Trigger>

                            <!-- ✅ Unchecked = HIDE password => CLOSED eye -->
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="IconOpen" Property="Opacity" Value="0"/>
                                <Setter TargetName="IconClosed" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="150" />
        </Grid.RowDefinitions>

        <!-- TOP AREA -->
        <Grid Grid.Row="0">
            <Border Margin="18"
                    Background="#FFFFFF"
                    CornerRadius="20"
                    BorderBrush="#110F172A"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.18"/>
                </Border.Effect>

                <Grid Margin="26">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="64"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER -->
                    <StackPanel Grid.Row="0"
                                HorizontalAlignment="Center"
                                Margin="0,2,0,18">
                        <Border Background="Transparent" Padding="2" Margin="0,0,0,10">
                          <Image Width="210"
       Height="110"
       Stretch="Uniform"
       RenderOptions.BitmapScalingMode="HighQuality"
       Source="/Views/Login/ekaling.png"/>

                        </Border>

                        <TextBlock Text="E-Kalinga"
                                   TextAlignment="Center"
                                   Foreground="{StaticResource Primary}"
                                   FontWeight="Bold"
                                   FontSize="26"
                                   Margin="0,0,0,2"/>

                        <TextBlock Text="Management System"
                                   TextAlignment="Center"
                                   Foreground="{StaticResource Primary}"
                                   FontWeight="SemiBold"
                                   FontSize="16"
                                   Opacity="0.95"/>
                    </StackPanel>

                    <!-- FORM -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Top">
                        <!-- Username -->
                        <TextBlock Text="Username"
                                   Foreground="{StaticResource Muted}"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Margin="0,0,0,6"/>

                        <Border Style="{StaticResource InputChrome}">
                            <Grid>
                                <TextBox x:Name="UsernameBox"
                                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Text="Enter your username"
                                           Margin="14,0,14,0"
                                           Foreground="#94A3B8"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Text, ElementName=UsernameBox}" Value=""/>
                                                        <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=UsernameBox}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <Rectangle Height="14" Fill="Transparent"/>

                        <!-- Password -->
                        <TextBlock Text="Password"
                                   Foreground="{StaticResource Muted}"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Margin="0,0,0,6"/>

                        <Border Style="{StaticResource InputChrome}">
                            <Grid>
                                <!-- Hidden password -->
                                <PasswordBox x:Name="PwdBox"
                                             Tag="0"
                                             Padding="14,10,48,10"
                                             PasswordChanged="PasswordBox_OnPasswordChanged">
                                    <PasswordBox.Style>
                                        <Style TargetType="PasswordBox" BasedOn="{StaticResource {x:Type PasswordBox}}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecked, ElementName=PwdToggle}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </PasswordBox.Style>
                                </PasswordBox>

                                <!-- Visible password -->
                                <TextBox x:Name="PwdText"
                                         Padding="14,10,48,10"
                                         TextChanged="PasswordText_OnTextChanged">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecked, ElementName=PwdToggle}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <!-- Placeholder (hidden mode) -->
                                <TextBlock Text="Enter your password"
                                           Margin="14,0,48,0"
                                           Foreground="#94A3B8"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsChecked, ElementName=PwdToggle}" Value="False"/>
                                                        <Condition Binding="{Binding Tag, ElementName=PwdBox}" Value="0"/>
                                                        <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=PwdBox}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Placeholder (show mode) -->
                                <TextBlock Text="Enter your password"
                                           Margin="14,0,48,0"
                                           Foreground="#94A3B8"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsChecked, ElementName=PwdToggle}" Value="True"/>
                                                        <Condition Binding="{Binding Text, ElementName=PwdText}" Value=""/>
                                                        <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=PwdText}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Eye button overlay -->
                                <ToggleButton x:Name="PwdToggle"
                                              Style="{StaticResource EyeToggle}"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Margin="0,0,6,0"
                                              Panel.ZIndex="5"
                                              Checked="PwdToggle_OnChecked"
                                              Unchecked="PwdToggle_OnUnchecked"
                                              ToolTip="Show / Hide password"/>
                            </Grid>
                        </Border>

                        <!-- Error / hint area -->
                        <Grid Margin="0,12,0,0" MinHeight="44">
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#C0392B"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </StackPanel>

                    <!-- BUTTON -->
                    <Grid Grid.Row="2">
                        <Button Style="{StaticResource PrimaryButton}"
                                Command="{Binding LoginCommand}"
                                Content="Log in"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- BOTTOM BANNER -->
        <Border Grid.Row="1" Background="#1F2A44">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="18,0">
                <TextBlock Text="Local Government Unit of Sulop"
                           Foreground="White"
                           FontWeight="SemiBold"
                           FontSize="13"
                           TextAlignment="Center"/>
                <TextBlock Text="Municipality of Sulop, Davao del Sur"
                           Foreground="#D6DDF0"
                           FontSize="12"
                           TextAlignment="Center"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>