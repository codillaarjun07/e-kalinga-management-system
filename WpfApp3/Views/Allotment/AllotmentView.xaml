<UserControl x:Class="WpfApp3.Views.Allotment.AllotmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfApp3.ViewModels.Allotment"
             xmlns:local="clr-namespace:WpfApp3.Views.Allotment"
             Background="Transparent">

    <UserControl.DataContext>
        <vm:AllotmentViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:EqualsToBoolConverter x:Key="EqualsToBoolConverter"/>

        <!-- Brushes -->
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F6F8FC"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#4F46E5"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#4338CA"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#EEF2FF"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#E7ECF5"/>
        <SolidColorBrush x:Key="BorderBrushLighter" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#E11D48"/>
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#BE123C"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FCFDFE"/>

        <!-- Shadows -->
        <DropShadowEffect x:Key="SoftShadow"
                          Color="#1E293B"
                          BlurRadius="24"
                          ShadowDepth="0"
                          Opacity="0.10"/>

        <DropShadowEffect x:Key="ModalShadow"
                          Color="#0F172A"
                          BlurRadius="32"
                          ShadowDepth="0"
                          Opacity="0.16"/>

        <!-- Text -->
        <Style x:Key="SectionTitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="FieldLabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Card -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLighter}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
        </Style>

        <!-- Backdrop -->
        <Style x:Key="BackdropButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="Transparent"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Buttons -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SoftIconButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="18,11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.50"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LightButton" TargetType="Button">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DangerHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PageButton" TargetType="Button">
            <Setter Property="MinWidth" Value="38"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentSoftBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RowActionButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="10"
                                Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Inputs -->
        <Style x:Key="InputBorderStyle" TargetType="Border">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlainInputTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="SelectionBrush" Value="#C7D2FE"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- DataGrid -->
        <Style x:Key="CenteredCellStyle" TargetType="DataGridCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style x:Key="CenteredTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <!-- Close button -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="10"
                                Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Remove default selection highlight -->
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#0F172A"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#0F172A"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">

        <!-- PAGE CONTENT -->
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TOP CARD -->
            <Border Grid.Row="0"
                    Style="{StaticResource CardBorder}"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Allotment List"
                               Style="{StaticResource SectionTitleText}"
                               Margin="0,0,0,16"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360"/>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search -->
                        <Border CornerRadius="14"
                                Background="{StaticResource InputBackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                Height="42"
                                Padding="14,0">
                            <Grid>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PlainInputTextBox}"/>

                                <TextBlock Text="Search here"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <Button Grid.Column="1"
                                Style="{StaticResource IconButton}"
                                Margin="10,0,0,0">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE721;"
                                       FontSize="15"
                                       Foreground="White"/>
                        </Button>

                        <Button Grid.Column="2"
                                Style="{StaticResource SoftIconButton}"
                                Margin="10,0,0,0">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE71C;"
                                       FontSize="15"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Button>

                        <Button Grid.Column="4"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding AddAllotmentCommand}"
                                Content="Add Allotment"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Found text -->
            <TextBlock Grid.Row="1"
                       Text="{Binding FoundText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12"
                       Margin="4,0,0,12"/>

            <!-- TABLE -->
            <Border Grid.Row="2"
                    Style="{StaticResource CardBorder}"
                    Padding="12">
                <DataGrid ItemsSource="{Binding Items}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          RowHeaderWidth="0"
                          Background="Transparent"
                          BorderThickness="0"
                          FontSize="12"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          ColumnHeaderHeight="44"
                          RowHeight="50"
                          IsReadOnly="True"
                          CanUserResizeRows="False"
                          CanUserReorderColumns="False"
                          CanUserSortColumns="False"
                          SelectionUnit="Cell"
                          SelectionMode="Single"
                          FocusVisualStyle="{x:Null}">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLighter}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="10,0"/>
                        </Style>

                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLighter}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="SnapsToDevicePixels" Value="True"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridRow">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <DataGridCellsPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FAFBFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="8,0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="44">
                            <DataGridTemplateColumn.Header>
                                <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"
                                            Width="60"
                                            CellStyle="{StaticResource CenteredCellStyle}"
                                            ElementStyle="{StaticResource CenteredTextBlockStyle}"/>

                        <DataGridTextColumn Header="Project Name"
                                            Binding="{Binding ProjectName}"
                                            Width="180"
                                            CellStyle="{StaticResource CenteredCellStyle}"
                                            ElementStyle="{StaticResource CenteredTextBlockStyle}"/>

                        <DataGridTextColumn Header="Description"
                                            Binding="{Binding Company}"
                                            Width="150"
                                            CellStyle="{StaticResource CenteredCellStyle}"
                                            ElementStyle="{StaticResource CenteredTextBlockStyle}"/>

                        <DataGridTextColumn Header="Department"
                                            Binding="{Binding Department}"
                                            Width="150"
                                            CellStyle="{StaticResource CenteredCellStyle}"
                                            ElementStyle="{StaticResource CenteredTextBlockStyle}"/>

                        <DataGridTextColumn Header="Source of Fund"
                                            Binding="{Binding SourceOfFund}"
                                            Width="150"
                                            CellStyle="{StaticResource CenteredCellStyle}"
                                            ElementStyle="{StaticResource CenteredTextBlockStyle}"/>

                        <DataGridTextColumn Header="No. of Ben."
                                            Binding="{Binding BeneficiariesCount}"
                                            Width="110"
                                            CellStyle="{StaticResource CenteredCellStyle}"
                                            ElementStyle="{StaticResource CenteredTextBlockStyle}"/>

                        <DataGridTextColumn Header="Budget"
                                            Binding="{Binding BudgetDisplay}"
                                            Width="180"
                                            CellStyle="{StaticResource CenteredCellStyle}"
                                            ElementStyle="{StaticResource CenteredTextBlockStyle}"/>

                        <DataGridTemplateColumn Width="96" Header="">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">

                                        <Button Style="{StaticResource RowActionButton}"
                                                Margin="0,0,8,0"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE70F;"
                                                       FontSize="14"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </Button>

                                        <Button Style="{StaticResource RowActionButton}"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE74D;"
                                                       FontSize="14"
                                                       Foreground="{StaticResource DangerBrush}"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Pagination -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,18,0,0">
                <Button Content="Previous"
                        Style="{StaticResource PageButton}"
                        Command="{Binding PreviousPageCommand}"/>

                <ItemsControl ItemsSource="{Binding PageNumbers}" Margin="8,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}"
                                    Command="{Binding DataContext.GoToPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PageButton}">
                                        <Style.Triggers>
                                            <DataTrigger Value="True">
                                                <DataTrigger.Binding>
                                                    <MultiBinding Converter="{StaticResource EqualsToBoolConverter}">
                                                        <Binding/>
                                                        <Binding Path="DataContext.CurrentPage"
                                                                 RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                    </MultiBinding>
                                                </DataTrigger.Binding>
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="Next"
                        Style="{StaticResource PageButton}"
                        Command="{Binding NextPageCommand}"/>
            </StackPanel>
        </Grid>

        <!-- ADD / EDIT MODAL -->
        <Grid Panel.ZIndex="900"
              Visibility="{Binding IsFormOpen, Converter={StaticResource BoolToVis}}"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Border Background="#660F172A"/>
            <Button Style="{StaticResource BackdropButton}" Command="{Binding CloseFormCommand}"/>

            <Border Width="940"
                    CornerRadius="24"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrushLighter}"
                    BorderThickness="1"
                    Padding="28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{StaticResource ModalShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding FormTitle}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                        <Button Grid.Column="1"
                                Style="{StaticResource CloseButtonStyle}"
                                Command="{Binding CloseFormCommand}">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE8BB;"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>
                    </Grid>

                    <!-- Form -->
                    <Grid Grid.Row="1" Margin="0,22,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <!-- Left column -->
                        <StackPanel Grid.Column="0">

                            <TextBlock Text="Project Name" Style="{StaticResource FieldLabelText}"/>
                            <Border Style="{StaticResource InputBorderStyle}">
                                <TextBox Text="{Binding ProjectNameInput, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PlainInputTextBox}"/>
                            </Border>
                            <TextBlock Text="{Binding ProjectNameError}"
                                       Foreground="{StaticResource DangerBrush}"
                                       FontSize="11"
                                       Margin="2,6,0,0"
                                       Visibility="{Binding HasProjectNameError, Converter={StaticResource BoolToVis}}"/>

                            <TextBlock Text="Department" Style="{StaticResource FieldLabelText}" Margin="0,18,0,8"/>
                            <ComboBox ItemsSource="{Binding Departments}"
                                      SelectedItem="{Binding DepartmentInput}"
                                      Style="{StaticResource ModernComboBox}"/>
                            <TextBlock Text="{Binding DepartmentError}"
                                       Foreground="{StaticResource DangerBrush}"
                                       FontSize="11"
                                       Margin="2,6,0,0"
                                       Visibility="{Binding HasDepartmentError, Converter={StaticResource BoolToVis}}"/>

                            <TextBlock Text="No of Beneficiaries" Style="{StaticResource FieldLabelText}" Margin="0,18,0,8"/>
                            <Border Style="{StaticResource InputBorderStyle}">
                                <TextBox Text="{Binding BeneficiariesInput, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PlainInputTextBox}"
                                         PreviewTextInput="DigitsOnly_PreviewTextInput"
                                         PreviewKeyDown="BlockSpace_PreviewKeyDown"
                                         Tag="digits"/>
                            </Border>
                            <TextBlock Text="{Binding BeneficiariesError}"
                                       Foreground="{StaticResource DangerBrush}"
                                       FontSize="11"
                                       Margin="2,6,0,0"
                                       Visibility="{Binding HasBeneficiariesError, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <!-- Right column -->
                        <StackPanel Grid.Column="2">

                            <TextBlock Text="Description" Style="{StaticResource FieldLabelText}"/>
                            <Border Style="{StaticResource InputBorderStyle}">
                                <TextBox Text="{Binding CompanyInput, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PlainInputTextBox}"/>
                            </Border>
                            <TextBlock Text="{Binding Error}"
                                       Foreground="{StaticResource DangerBrush}"
                                       FontSize="11"
                                       Margin="2,6,0,0"
                                       Visibility="{Binding HasCompanyError, Converter={StaticResource BoolToVis}}"/>

                            <TextBlock Text="Source of Fund" Style="{StaticResource FieldLabelText}" Margin="0,18,0,8"/>
                            <ComboBox ItemsSource="{Binding SourcesOfFund}"
                                      SelectedItem="{Binding SourceOfFundInput}"
                                      Style="{StaticResource ModernComboBox}"/>
                            <TextBlock Text="{Binding SourceOfFundError}"
                                       Foreground="{StaticResource DangerBrush}"
                                       FontSize="11"
                                       Margin="2,6,0,0"
                                       Visibility="{Binding HasSourceOfFundError, Converter={StaticResource BoolToVis}}"/>

                            <TextBlock Text="Budget Type" Style="{StaticResource FieldLabelText}" Margin="0,18,0,8"/>
                            <ComboBox ItemsSource="{Binding BudgetTypes}"
                                      SelectedItem="{Binding BudgetTypeInput}"
                                      Style="{StaticResource ModernComboBox}"/>

                            <!-- MONEY PANEL -->
                            <StackPanel Margin="0,14,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BudgetTypeInput}" Value="Money">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="Budget Amount (₱)" Style="{StaticResource FieldLabelText}"/>
                                <Border Style="{StaticResource InputBorderStyle}">
                                    <TextBox Text="{Binding BudgetAmountInput, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource PlainInputTextBox}"
                                             PreviewTextInput="Money_PreviewTextInput"
                                             PreviewKeyDown="BlockSpace_PreviewKeyDown"
                                             Tag="money"/>
                                </Border>
                                <TextBlock Text="{Binding BudgetAmountError}"
                                           Foreground="{StaticResource DangerBrush}"
                                           FontSize="11"
                                           Margin="2,6,0,0"
                                           Visibility="{Binding HasBudgetAmountError, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>

                            <!-- IN-KIND PANEL -->
                            <StackPanel Margin="0,14,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BudgetTypeInput}" Value="InKind">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="In-kind Budget" Style="{StaticResource FieldLabelText}"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource InputBorderStyle}">
                                        <TextBox Text="{Binding BudgetQtyInput, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource PlainInputTextBox}"
                                                 PreviewTextInput="DigitsOnly_PreviewTextInput"
                                                 PreviewKeyDown="BlockSpace_PreviewKeyDown"
                                                 Tag="digits"/>
                                    </Border>

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="{Binding BudgetQtyError}"
                                               Foreground="{StaticResource DangerBrush}"
                                               FontSize="11"
                                               Margin="2,6,0,0"
                                               Visibility="{Binding HasBudgetQtyError, Converter={StaticResource BoolToVis}}"/>

                                    <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource InputBorderStyle}">
                                        <TextBox Text="{Binding BudgetUnitInput, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource PlainInputTextBox}"/>
                                    </Border>

                                    <TextBlock Grid.Row="1" Grid.Column="2"
                                               Text="{Binding BudgetUnitError}"
                                               Foreground="{StaticResource DangerBrush}"
                                               FontSize="11"
                                               Margin="2,6,0,0"
                                               Visibility="{Binding HasBudgetUnitError, Converter={StaticResource BoolToVis}}"/>
                                </Grid>

                                <TextBlock Text="Example: 100 | sacks of rice"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Save -->
                    <Grid Grid.Row="2" Margin="0,28,0,0">
                        <Button Content="Save"
                                Width="180"
                                Height="44"
                                HorizontalAlignment="Right"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveFormCommand}"
                                IsEnabled="{Binding CanSave}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- DELETE MODAL -->
        <Grid Panel.ZIndex="910"
              Visibility="{Binding IsDeleteOpen, Converter={StaticResource BoolToVis}}"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Border Background="#660F172A"/>
            <Button Style="{StaticResource BackdropButton}" Command="{Binding CancelDeleteCommand}"/>

            <Border Width="540"
                    CornerRadius="24"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrushLighter}"
                    BorderThickness="1"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{StaticResource ModalShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Delete Allotment"
                                   Foreground="{StaticResource DangerBrush}"
                                   FontSize="20"
                                   FontWeight="Bold"/>

                        <Button Grid.Column="1"
                                Style="{StaticResource CloseButtonStyle}"
                                Command="{Binding CancelDeleteCommand}">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE8BB;"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Text="{Binding DeleteMessage}"
                               Margin="0,14,0,0"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap"/>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,18,0,0">
                        <Button Content="Cancel"
                                Width="140"
                                Height="42"
                                Style="{StaticResource LightButton}"
                                Command="{Binding CancelDeleteCommand}"/>

                        <Button Content="Confirm"
                                Width="140"
                                Height="42"
                                Margin="14,0,0,0"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding ConfirmDeleteCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>