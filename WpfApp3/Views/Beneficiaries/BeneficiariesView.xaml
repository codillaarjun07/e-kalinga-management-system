<UserControl x:Class="WpfApp3.Views.Beneficiaries.BeneficiariesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfApp3.ViewModels.Beneficiaries"
             xmlns:conv="clr-namespace:WpfApp3.Views.Allotment">

    <UserControl.DataContext>
        <vm:BeneficiariesViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:EqualsToBoolConverter x:Key="EqualsToBoolConverter"/>

        <!-- ========================= -->
        <!-- COLORS / BRUSHES          -->
        <!-- ========================= -->
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F6F8FC"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#4F46E5"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#4338CA"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#EEF2FF"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#E7ECF5"/>
        <SolidColorBrush x:Key="BorderBrushLighter" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#E11D48"/>
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#BE123C"/>

        <DropShadowEffect x:Key="CardShadow"
                          Color="#1E293B"
                          BlurRadius="28"
                          ShadowDepth="0"
                          Opacity="0.10"/>

        <!-- ========================= -->
        <!-- TYPOGRAPHY                -->
        <!-- ========================= -->
        <Style x:Key="SectionTitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="FieldLabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- ========================= -->
        <!-- GENERIC CARDS             -->
        <!-- ========================= -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLighter}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <!-- Backdrop button -->
        <Style x:Key="BackdropButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="Transparent"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small icon buttons -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.90"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="18,11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Light button -->
        <Style x:Key="LightButton" TargetType="Button">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pagination -->
        <Style x:Key="PageButton" TargetType="Button">
            <Setter Property="MinWidth" Value="38"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentSoftBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Row action button -->
        <Style x:Key="RowActionButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="10"
                                Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFF1F2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- INPUT FIX -->
        <Style x:Key="InputBorderStyle" TargetType="Border">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ReadOnlyInputBorderStyle" TargetType="Border" BasedOn="{StaticResource InputBorderStyle}">
            <Setter Property="Background" Value="#F8FAFC"/>
        </Style>

        <Style x:Key="PlainInputTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="SelectionBrush" Value="#C7D2FE"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <!-- ComboBox -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinHeight" Value="42"/>
        </Style>

        <!-- Cell alignment -->
        <Style x:Key="CenteredCellStyle" TargetType="DataGridCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style x:Key="CenteredTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="RoundedPrimary" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Width" Value="160"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="RoundedDanger" TargetType="Button">
            <Setter Property="Width" Value="140"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DangerHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close button -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="10"
                                Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <!-- PAGE -->
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TOP CARD -->
            <Border Grid.Row="0"
                    Style="{StaticResource CardBorder}"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340"/>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Select Project / Allotment"
                               Style="{StaticResource FieldLabelText}"/>

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            CornerRadius="14"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            Background="#FCFDFE">
                        <ComboBox ItemsSource="{Binding Projects}"
                                  SelectedItem="{Binding SelectedProject}"
                                  DisplayMemberPath="ProjectName"
                                  Style="{StaticResource ModernComboBox}"/>
                    </Border>

                    <Button Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource IconButton}"
                            Margin="10,0,0,0"
                            Command="{Binding OpenProjectDetailsCommand}">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE890;"
                                   FontSize="15"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Button>

                    <StackPanel Grid.Row="1"
                                Grid.Column="3"
                                VerticalAlignment="Center">
                        <TextBlock Text="Total Budget"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding TotalBudgetText}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- FILTER / ACTION CARD -->
            <Border Grid.Row="1"
                    Style="{StaticResource CardBorder}"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Endorsed Beneficiaries"
                               Style="{StaticResource SectionTitleText}"
                               VerticalAlignment="Center"/>

                    <Button Grid.Row="0"
                            Grid.Column="1"
                            Grid.RowSpan="3"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding OpenAddBeneficiariesCommand}"
                            VerticalAlignment="Center"
                            Content="Add Beneficiaries"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="Select Classification"
                               Style="{StaticResource FieldLabelText}"
                               Margin="0,14,0,8"
                               HorizontalAlignment="Left"/>

                    <Border Grid.Row="2"
                            Grid.Column="0"
                            Width="340"
                            HorizontalAlignment="Left"
                            CornerRadius="14"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            Background="#FCFDFE">
                        <ComboBox ItemsSource="{Binding ClassificationOptions}"
                                  SelectedItem="{Binding SelectedClassification}"
                                  Style="{StaticResource ModernComboBox}"/>
                    </Border>
                </Grid>
            </Border>

            <!-- FOUND TEXT -->
            <TextBlock Grid.Row="2"
                       Text="{Binding FoundText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12"
                       Margin="4,0,0,12"/>

            <!-- TABLE CARD -->
            <Border Grid.Row="3"
                    Style="{StaticResource CardBorder}"
                    Padding="12">
                <DataGrid ItemsSource="{Binding Items}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          RowHeaderWidth="0"
                          Background="Transparent"
                          BorderThickness="0"
                          FontSize="12"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          ColumnHeaderHeight="44"
                          RowHeight="50"
                          IsReadOnly="True"
                          SelectionUnit="FullRow"
                          SelectionMode="Single"
                          FocusVisualStyle="{x:Null}">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLighter}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="10,0"/>
                        </Style>

                        <Style TargetType="DataGridRow">
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLighter}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FAFBFF"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <Style TargetType="DataGridCell" BasedOn="{StaticResource CenteredCellStyle}">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"
                                            Width="60"
                                            CellStyle="{StaticResource CenteredCellStyle}"
                                            ElementStyle="{StaticResource CenteredTextBlockStyle}"/>

                        <DataGridTextColumn Header="First Name"
                                            Binding="{Binding FirstName}"
                                            Width="160"
                                            CellStyle="{StaticResource CenteredCellStyle}"
                                            ElementStyle="{StaticResource CenteredTextBlockStyle}"/>

                        <DataGridTextColumn Header="Last Name"
                                            Binding="{Binding LastName}"
                                            Width="160"
                                            CellStyle="{StaticResource CenteredCellStyle}"
                                            ElementStyle="{StaticResource CenteredTextBlockStyle}"/>

                        <DataGridTextColumn Header="Gender"
                                            Binding="{Binding Gender}"
                                            Width="120"
                                            CellStyle="{StaticResource CenteredCellStyle}"
                                            ElementStyle="{StaticResource CenteredTextBlockStyle}"/>

                        <DataGridTextColumn Header="Barangay"
                                            Binding="{Binding Barangay}"
                                            Width="160"
                                            CellStyle="{StaticResource CenteredCellStyle}"
                                            ElementStyle="{StaticResource CenteredTextBlockStyle}"/>

                        <DataGridTextColumn Header="Classification"
                                            Binding="{Binding Classification}"
                                            Width="150"
                                            CellStyle="{StaticResource CenteredCellStyle}"
                                            ElementStyle="{StaticResource CenteredTextBlockStyle}"/>

                        <DataGridTextColumn Header="Share"
                                            Binding="{Binding ShareText}"
                                            Width="160"
                                            CellStyle="{StaticResource CenteredCellStyle}"
                                            ElementStyle="{StaticResource CenteredTextBlockStyle}"/>

                        <DataGridTemplateColumn Width="90" Header="">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <Button Style="{StaticResource RowActionButton}"
                                                Command="{Binding DataContext.OpenRemoveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE74D;"
                                                       FontSize="14"
                                                       Foreground="{StaticResource DangerBrush}"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- PAGINATION -->
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,18,0,0">
                <Button Content="Previous"
                        Style="{StaticResource PageButton}"
                        Command="{Binding PreviousPageCommand}"/>

                <ItemsControl ItemsSource="{Binding PageNumbers}" Margin="8,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}"
                                    Command="{Binding DataContext.GoToPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PageButton}">
                                        <Style.Triggers>
                                            <DataTrigger Value="True">
                                                <DataTrigger.Binding>
                                                    <MultiBinding Converter="{StaticResource EqualsToBoolConverter}">
                                                        <Binding/>
                                                        <Binding Path="DataContext.CurrentPage"
                                                                 RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                    </MultiBinding>
                                                </DataTrigger.Binding>
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="Next"
                        Style="{StaticResource PageButton}"
                        Command="{Binding NextPageCommand}"/>
            </StackPanel>
        </Grid>

        <!-- MODAL 1: PROJECT DETAILS -->
        <Grid Panel.ZIndex="900"
              Visibility="{Binding IsProjectDetailsOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#660F172A"/>
            <Button Style="{StaticResource BackdropButton}"
                    Command="{Binding CloseProjectDetailsCommand}"/>

            <Border Width="920"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrushLighter}"
                    BorderThickness="1"
                    CornerRadius="24"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Project Details"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                        <Button Grid.Column="1"
                                Style="{StaticResource CloseButtonStyle}"
                                Command="{Binding CloseProjectDetailsCommand}">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE8BB;"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Project Name" Style="{StaticResource FieldLabelText}"/>
                            <Border Style="{StaticResource ReadOnlyInputBorderStyle}">
                                <TextBox Text="{Binding ProjectNameDetails}"
                                         Style="{StaticResource PlainInputTextBox}"
                                         IsReadOnly="True"/>
                            </Border>

                            <TextBlock Text="Department"
                                       Style="{StaticResource FieldLabelText}"
                                       Margin="0,16,0,8"/>
                            <Border Style="{StaticResource ReadOnlyInputBorderStyle}">
                                <TextBox Text="{Binding DepartmentDetails}"
                                         Style="{StaticResource PlainInputTextBox}"
                                         IsReadOnly="True"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Company" Style="{StaticResource FieldLabelText}"/>
                            <Border Style="{StaticResource ReadOnlyInputBorderStyle}">
                                <TextBox Text="{Binding CompanyDetails}"
                                         Style="{StaticResource PlainInputTextBox}"
                                         IsReadOnly="True"/>
                            </Border>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Source of Fund" Style="{StaticResource FieldLabelText}"/>
                                    <Border Style="{StaticResource ReadOnlyInputBorderStyle}">
                                        <TextBox Text="{Binding SourceOfFundDetails}"
                                                 Style="{StaticResource PlainInputTextBox}"
                                                 IsReadOnly="True"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Total Budget" Style="{StaticResource FieldLabelText}"/>
                                    <Border Style="{StaticResource ReadOnlyInputBorderStyle}">
                                        <TextBox Text="{Binding TotalBudgetDetails}"
                                                 Style="{StaticResource PlainInputTextBox}"
                                                 IsReadOnly="True"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- MODAL 2: ADD BENEFICIARIES -->
        <Grid Panel.ZIndex="910"
              Visibility="{Binding IsAddBeneficiariesOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#660F172A"/>
            <Button Style="{StaticResource BackdropButton}"
                    Command="{Binding CloseAddBeneficiariesCommand}"/>

            <Border Width="860"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrushLighter}"
                    BorderThickness="1"
                    CornerRadius="24"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Add Beneficiaries"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                        <Button Grid.Column="1"
                                Style="{StaticResource CloseButtonStyle}"
                                Command="{Binding CloseAddBeneficiariesCommand}">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE8BB;"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>
                    </Grid>

                    <!-- Search + Add -->
                    <Grid Grid.Row="1" Margin="0,16,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360"/>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Height="42"
                                CornerRadius="14"
                                Background="#FCFDFE"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                Padding="14,0">
                            <TextBox Text="{Binding AddSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource PlainInputTextBox}"/>
                        </Border>

                        <Button Grid.Column="1"
                                Style="{StaticResource IconButton}"
                                Margin="10,0,0,0">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE721;"
                                       FontSize="15"
                                       Foreground="White"/>
                        </Button>

                        <Button Grid.Column="3"
                                Style="{StaticResource PrimaryButton}"
                                Padding="16,10"
                                Content="{Binding AddButtonText}"
                                Command="{Binding ConfirmAddSelectedCommand}"/>
                    </Grid>

                    <TextBlock Grid.Row="2"
                               Text="{Binding AddFoundText}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               Margin="2,0,0,10"/>

                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- TABLE -->
                        <Border Grid.Row="0"
                                MinHeight="390"
                                CornerRadius="18"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                Background="White"
                                Padding="8">

                            <DataGrid ItemsSource="{Binding AddPagedItems}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      RowHeaderWidth="0"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      FontSize="12"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      ColumnHeaderHeight="42"
                                      RowHeight="46"
                                      IsReadOnly="False"
                                      SelectionUnit="FullRow"
                                      SelectionMode="Single"
                                      FocusVisualStyle="{x:Null}">

                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLighter}"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="8,0"/>
                                    </Style>

                                    <Style TargetType="DataGridRow">
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLighter}"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FAFBFF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.Resources>

                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="44">
                                        <DataGridTemplateColumn.Header>
                                            <CheckBox HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      IsThreeState="True"
                                                      IsChecked="{Binding IsAddAllSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataGridTemplateColumn.Header>

                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Focusable="False"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>

                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <CheckBox HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Focusable="False"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="140" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Last Name" Binding="{Binding LastName}" Width="140" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Gender" Binding="{Binding Gender}" Width="110" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Barangay" Binding="{Binding Barangay}" Width="140" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Classification" Binding="{Binding Classification}" Width="140" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Pagination -->
                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,14,0,0">

                            <Button Content="Previous"
                                    Style="{StaticResource PageButton}"
                                    Command="{Binding AddPreviousPageCommand}"/>

                            <ItemsControl ItemsSource="{Binding AddPageNumbers}" Margin="8,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding}"
                                                Command="{Binding DataContext.AddGoToPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource PageButton}">
                                                    <Style.Triggers>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <MultiBinding Converter="{StaticResource EqualsToBoolConverter}">
                                                                    <Binding/>
                                                                    <Binding Path="DataContext.AddCurrentPage"
                                                                             RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                </MultiBinding>
                                                            </DataTrigger.Binding>
                                                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Content="Next"
                                    Style="{StaticResource PageButton}"
                                    Command="{Binding AddNextPageCommand}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- MODAL 3: EDIT SHARE -->
        <Grid Panel.ZIndex="920"
              Visibility="{Binding IsEditShareOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#660F172A"/>
            <Button Style="{StaticResource BackdropButton}" Command="{Binding CloseEditShareCommand}"/>

            <Border Width="540"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrushLighter}"
                    BorderThickness="1"
                    CornerRadius="24"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Edit Share"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                        <Button Grid.Column="1"
                                Style="{StaticResource CloseButtonStyle}"
                                Command="{Binding CloseEditShareCommand}">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE8BB;"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>
                    </Grid>

                    <!-- MONEY -->
                    <StackPanel Grid.Row="1" Margin="0,16,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedProject.BudgetType}" Value="Money">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="Share Amount (₱)" Style="{StaticResource FieldLabelText}"/>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <TextBox Text="{Binding ShareAmountInput, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource PlainInputTextBox}"
                                     PreviewTextInput="Money_PreviewTextInput"
                                     PreviewKeyDown="BlockSpace_PreviewKeyDown"/>
                        </Border>

                        <TextBlock Text="{Binding ShareAmountError}"
                                   Foreground="{StaticResource DangerBrush}"
                                   FontSize="11"
                                   Margin="2,8,0,0"
                                   Visibility="{Binding HasShareAmountError, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- IN-KIND -->
                    <StackPanel Grid.Row="1" Margin="0,16,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedProject.BudgetType}" Value="InKind">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="In-kind Share" Style="{StaticResource FieldLabelText}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource InputBorderStyle}">
                                <TextBox Text="{Binding ShareQtyInput, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PlainInputTextBox}"
                                         PreviewTextInput="DigitsOnly_PreviewTextInput"
                                         PreviewKeyDown="BlockSpace_PreviewKeyDown"/>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource InputBorderStyle}">
                                <TextBox Text="{Binding ShareUnitInput, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PlainInputTextBox}"/>
                            </Border>
                        </Grid>

                        <TextBlock Text="{Binding ShareInKindError}"
                                   Foreground="{StaticResource DangerBrush}"
                                   FontSize="11"
                                   Margin="2,8,0,0"
                                   Visibility="{Binding HasShareInKindError, Converter={StaticResource BoolToVis}}"/>

                        <TextBlock Text="Example: 10 | sacks of rice"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,18,0,0">
                        <Button Content="Cancel"
                                Width="120"
                                Height="40"
                                Style="{StaticResource LightButton}"
                                Command="{Binding CloseEditShareCommand}"/>

                        <Button Content="Confirm"
                                Margin="14,0,0,0"
                                Style="{StaticResource RoundedPrimary}"
                                Command="{Binding ConfirmEditShareCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- MODAL 4: REMOVE ASSIGNMENT -->
        <Grid Panel.ZIndex="930"
              Visibility="{Binding IsRemoveOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#660F172A"/>
            <Button Style="{StaticResource BackdropButton}" Command="{Binding CloseRemoveCommand}"/>

            <Border Width="540"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrushLighter}"
                    BorderThickness="1"
                    CornerRadius="24"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Remove Beneficiary"
                                   Foreground="{StaticResource DangerBrush}"
                                   FontSize="20"
                                   FontWeight="Bold"/>

                        <Button Grid.Column="1"
                                Style="{StaticResource CloseButtonStyle}"
                                Command="{Binding CloseRemoveCommand}">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE8BB;"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Text="{Binding RemoveMessage}"
                               Margin="0,14,0,0"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap"/>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,18,0,0">
                        <Button Content="Cancel"
                                Width="140"
                                Height="42"
                                Style="{StaticResource LightButton}"
                                Command="{Binding CloseRemoveCommand}"/>

                        <Button Content="Confirm"
                                Margin="16,0,0,0"
                                Style="{StaticResource RoundedDanger}"
                                Command="{Binding ConfirmRemoveCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>