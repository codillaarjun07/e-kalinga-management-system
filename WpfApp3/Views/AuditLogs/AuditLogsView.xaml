<UserControl x:Class="WpfApp3.Views.AuditLogs.AuditLogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WpfApp3.ViewModels.AuditLogs"
             xmlns:conv="clr-namespace:WpfApp3.Views.Allotment"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=vm:AuditLogsViewModel}">

    <UserControl.DataContext>
        <vm:AuditLogsViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>

        <conv:EqualsToBoolConverter x:Key="EqualsToBoolConverter"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1F2A44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1F2A44"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="22,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#F8FAFD"/>
            <Setter Property="Foreground" Value="#2E3A59"/>
            <Setter Property="BorderBrush" Value="#E5ECF7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background" Value="#EEF2F8"/>
            <Setter Property="Foreground" Value="#1F2A44"/>
            <Setter Property="BorderBrush" Value="#DCE5F2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="160"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabButtonAll" TargetType="Button" BasedOn="{StaticResource TabButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedTab}" Value="ALL">
                    <Setter Property="Background" Value="#1F2A44"/>
                    <Setter Property="BorderBrush" Value="#1F2A44"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabButtonCreate" TargetType="Button" BasedOn="{StaticResource TabButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedTab}" Value="CREATE">
                    <Setter Property="Background" Value="#1F2A44"/>
                    <Setter Property="BorderBrush" Value="#1F2A44"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabButtonUpdate" TargetType="Button" BasedOn="{StaticResource TabButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedTab}" Value="UPDATE">
                    <Setter Property="Background" Value="#1F2A44"/>
                    <Setter Property="BorderBrush" Value="#1F2A44"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabButtonDelete" TargetType="Button" BasedOn="{StaticResource TabButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedTab}" Value="DELETE">
                    <Setter Property="Background" Value="#1F2A44"/>
                    <Setter Property="BorderBrush" Value="#1F2A44"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#F8FAFD"/>
            <Setter Property="BorderBrush" Value="#E5ECF7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#2E3A59"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="HeaderCellText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="BodyCellText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#2E3A59"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="PageNumberButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="Padding" Value="10,8"/>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource EqualsToBoolConverter}">
                            <Binding Path="DataContext.CurrentPage"
                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                            <Binding/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="#1F2A44"/>
                    <Setter Property="BorderBrush" Value="#1F2A44"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid Background="#F3F5F9">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="34,28,34,28">

                <Border Background="White"
                        BorderBrush="#EEF2FF"
                        BorderThickness="1"
                        CornerRadius="26"
                        Padding="30">
                    <StackPanel>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Audit Logs"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#294287"/>

                                <TextBlock Text="Track create, update, and delete operations with actor name, date, and detailed description."
                                           Margin="0,8,0,0"
                                           FontSize="13"
                                           Foreground="#7184A3"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="Refresh"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding RefreshCommand}"
                                    MinWidth="150"
                                    Height="44"
                                    VerticalAlignment="Top"/>
                        </Grid>

                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SearchBoxStyle}"
                                 Height="46"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,18"
                                 ToolTip="Search audit logs"/>

                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{Binding StatusBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,20"/>

                        <WrapPanel Margin="0,0,0,20">
                            <Button Content="ALL"
                                    Style="{StaticResource TabButtonAll}"
                                    Command="{Binding SelectTabCommand}"
                                    CommandParameter="ALL"
                                    Margin="0,0,12,12"/>

                            <Button Content="CREATE"
                                    Style="{StaticResource TabButtonCreate}"
                                    Command="{Binding SelectTabCommand}"
                                    CommandParameter="CREATE"
                                    Margin="0,0,12,12"/>

                            <Button Content="UPDATE"
                                    Style="{StaticResource TabButtonUpdate}"
                                    Command="{Binding SelectTabCommand}"
                                    CommandParameter="UPDATE"
                                    Margin="0,0,12,12"/>

                            <Button Content="DELETE"
                                    Style="{StaticResource TabButtonDelete}"
                                    Command="{Binding SelectTabCommand}"
                                    CommandParameter="DELETE"
                                    Margin="0,0,12,12"/>
                        </WrapPanel>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding FoundText}"
                                       Foreground="#7184A3"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding PageSummaryText}"
                                       Foreground="#94A3B8"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Border Background="White"
                                BorderBrush="#E7EEF8"
                                BorderThickness="1"
                                CornerRadius="20"
                                Padding="10">
                            <StackPanel>
                                <Grid Margin="10,6,10,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="190"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="ID" Style="{StaticResource HeaderCellText}"/>
                                    <TextBlock Grid.Column="1" Text="Type" Style="{StaticResource HeaderCellText}"/>
                                    <TextBlock Grid.Column="2" Text="User" Style="{StaticResource HeaderCellText}"/>
                                    <TextBlock Grid.Column="3" Text="Description" Style="{StaticResource HeaderCellText}"/>
                                    <TextBlock Grid.Column="4" Text="Date / Time" Style="{StaticResource HeaderCellText}"/>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#EEF2FF"
                                                    BorderThickness="0,1,0,0"
                                                    Padding="10,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="190"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Id}"
                                                               Style="{StaticResource BodyCellText}"/>

                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding OperationType}"
                                                               Style="{StaticResource BodyCellText}"
                                                               Margin="0,0,10,0"/>

                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding ActorName}"
                                                               Style="{StaticResource BodyCellText}"
                                                               Margin="0,0,12,0"/>

                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding Description}"
                                                               Style="{StaticResource BodyCellText}"
                                                               Margin="0,0,12,0"/>

                                                    <TextBlock Grid.Column="4"
                                                               Text="{Binding CreatedAtText}"
                                                               Style="{StaticResource BodyCellText}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="No audit logs found."
                                           Foreground="#94A3B8"
                                           FontStyle="Italic"
                                           HorizontalAlignment="Center"
                                           Margin="0,18,0,10">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Items.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding PagingStatusText}"
                                       VerticalAlignment="Center"
                                       Foreground="#7184A3"
                                       FontSize="13"/>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button Content="Previous"
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding PreviousPageCommand}"
                                        IsEnabled="{Binding CanGoPrevious}"
                                        Margin="0,0,10,0"/>

                                <ItemsControl ItemsSource="{Binding PageNumbers}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding}"
                                                    Style="{StaticResource PageNumberButton}"
                                                    Command="{Binding DataContext.GoToPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,8,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Content="Next"
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding NextPageCommand}"
                                        IsEnabled="{Binding CanGoNext}"/>
                            </StackPanel>
                        </Grid>

                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>