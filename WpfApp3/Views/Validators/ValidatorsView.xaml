<UserControl x:Class="WpfApp3.Views.Validators.ValidatorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfApp3.ViewModels.Validators"
             xmlns:models="clr-namespace:WpfApp3.Models"
             Background="Transparent">

    <UserControl.DataContext>
        <vm:ValidatorsViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ========================= -->
        <!-- COLORS / BRUSHES          -->
        <!-- ========================= -->
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F6F8FC"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#4F46E5"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#4338CA"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#EEF2FF"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#E7ECF5"/>
        <SolidColorBrush x:Key="BorderBrushLighter" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#E11D48"/>
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#BE123C"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FCFDFE"/>

        <DropShadowEffect x:Key="CardShadow"
                          Color="#1E293B"
                          BlurRadius="26"
                          ShadowDepth="0"
                          Opacity="0.10"/>

        <DropShadowEffect x:Key="ModalShadow"
                          Color="#0F172A"
                          BlurRadius="32"
                          ShadowDepth="0"
                          Opacity="0.16"/>

        <!-- ========================= -->
        <!-- TEXT                      -->
        <!-- ========================= -->
        <Style x:Key="SectionTitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="FieldLabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- ========================= -->
        <!-- CARDS                     -->
        <!-- ========================= -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLighter}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <!-- ========================= -->
        <!-- BUTTONS                   -->
        <!-- ========================= -->
        <Style x:Key="BackdropButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="Transparent"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="18,11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallOutlineButton" TargetType="Button" BasedOn="{StaticResource OutlineButton}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopTabPill" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusPill" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RowActionButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="10"
                                Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========================= -->
        <!-- INPUT FIX                 -->
        <!-- ========================= -->
        <Style x:Key="InputBorderStyle" TargetType="Border">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlainInputTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="SelectionBrush" Value="#C7D2FE"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- ========================= -->
        <!-- TABLE                     -->
        <!-- ========================= -->
        <Style x:Key="CenteredCellStyle" TargetType="DataGridCell">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <!-- selection -->
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#0F172A"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#0F172A"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top tabs -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                <Button Content="Not Yet Validated"
                        Command="{Binding SetMainTabCommand}"
                        CommandParameter="{x:Static vm:ValidatorsMainTab.NotYetValidated}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TopTabPill}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveMainTab}" Value="{x:Static vm:ValidatorsMainTab.NotYetValidated}">
                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Validated"
                        Margin="10,0,0,0"
                        Command="{Binding SetMainTabCommand}"
                        CommandParameter="{x:Static vm:ValidatorsMainTab.Validated}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TopTabPill}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveMainTab}" Value="{x:Static vm:ValidatorsMainTab.Validated}">
                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- ============================= -->
            <!-- NOT YET VALIDATED SECTION     -->
            <!-- ============================= -->
            <Grid Grid.Row="2">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveMainTab}" Value="{x:Static vm:ValidatorsMainTab.NotYetValidated}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- People -->
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="People"
                                   Style="{StaticResource SectionTitleText}"/>

                        <Grid Grid.Row="1" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="42"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource InputBorderStyle}">
                                <TextBox Text="{Binding SearchNotYetText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PlainInputTextBox}"/>
                            </Border>

                            <Button Grid.Column="2"
                                    Style="{StaticResource IconButton}"
                                    Command="{Binding SearchNotYetCommand}">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE721;"
                                           FontSize="15"
                                           Foreground="White"/>
                            </Button>
                        </Grid>

                        <TextBlock Grid.Row="2"
                                   Text="{Binding NotYetFoundText}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   Margin="2,10,0,10"/>

                        <ListBox Grid.Row="3"
                                 ItemsSource="{Binding NotYetItems}"
                                 SelectedItem="{Binding SelectedPerson, Mode=TwoWay}"
                                 BorderThickness="0"
                                 Background="Transparent">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="12"/>
                                    <Setter Property="Margin" Value="0,0,0,8"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="12"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                            <Condition Property="IsSelected" Value="True"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ValidatorRecord}">
                                    <TextBlock Text="{Binding FullName}" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Profile -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Profile Information"
                                   Style="{StaticResource SectionTitleText}"/>

                        <Grid Grid.Row="1" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Width="140">
                                <Grid Width="140" Height="140">
                                    <Ellipse Fill="#D9ECFF"/>

                                    <Ellipse>
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding SelectedPerson.ProfileImagePreview}" Stretch="UniformToFill"/>
                                        </Ellipse.Fill>
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedPerson.HasProfileImage}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>

                                    <TextBlock Text="👤" FontSize="44" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedPerson.HasProfileImage}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <Button Content="Upload Photo"
                                        Margin="0,10,0,0"
                                        Style="{StaticResource SmallOutlineButton}"
                                        Command="{Binding UploadProfileImageCommand}"/>

                                <Button Content="Remove"
                                        Margin="0,8,0,0"
                                        Command="{Binding RemoveProfileImageCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SmallOutlineButton}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedPerson.HasProfileImage}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>

                            <!-- Left fields -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Beneficiary ID" Style="{StaticResource FieldLabelText}"/>
                                <Border Style="{StaticResource InputBorderStyle}">
                                    <TextBox Text="{Binding SelectedPerson.BeneficiaryId, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource PlainInputTextBox}"/>
                                </Border>

                                <TextBlock Text="First Name" Style="{StaticResource FieldLabelText}" Margin="0,12,0,0"/>
                                <Border Style="{StaticResource InputBorderStyle}">
                                    <TextBox Text="{Binding SelectedPerson.FirstName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource PlainInputTextBox}"/>
                                </Border>

                                <TextBlock Text="Gender" Style="{StaticResource FieldLabelText}" Margin="0,12,0,0"/>
                                <ComboBox Style="{StaticResource ModernComboBox}"
                                          ItemsSource="{Binding GenderOptions}"
                                          SelectedItem="{Binding SelectedPerson.Gender, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Text="Barangay" Style="{StaticResource FieldLabelText}" Margin="0,12,0,0"/>
                                <Border Style="{StaticResource InputBorderStyle}">
                                    <TextBox Text="{Binding SelectedPerson.Barangay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource PlainInputTextBox}"/>
                                </Border>
                            </StackPanel>

                            <!-- Right fields -->
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Civil Registry ID" Style="{StaticResource FieldLabelText}"/>
                                <Border Style="{StaticResource InputBorderStyle}">
                                    <TextBox Text="{Binding SelectedPerson.CivilRegistryId, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource PlainInputTextBox}"/>
                                </Border>

                                <TextBlock Text="Middle Name" Style="{StaticResource FieldLabelText}" Margin="0,12,0,0"/>
                                <Border Style="{StaticResource InputBorderStyle}">
                                    <TextBox Text="{Binding SelectedPerson.MiddleName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource PlainInputTextBox}"/>
                                </Border>

                                <TextBlock Text="Last Name" Style="{StaticResource FieldLabelText}" Margin="0,12,0,0"/>
                                <Border Style="{StaticResource InputBorderStyle}">
                                    <TextBox Text="{Binding SelectedPerson.LastName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource PlainInputTextBox}"/>
                                </Border>

                                <TextBlock Text="Classification" Style="{StaticResource FieldLabelText}" Margin="0,12,0,0"/>
                                <ComboBox Style="{StaticResource ModernComboBox}"
                                          ItemsSource="{Binding ClassificationOptions}"
                                          SelectedItem="{Binding SelectedPerson.Classification, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <!-- Address -->
                            <StackPanel Grid.Column="2" Grid.ColumnSpan="3" Margin="0,310,0,0">
                                <TextBlock Text="Present Address" Style="{StaticResource FieldLabelText}"/>
                                <Border Style="{StaticResource InputBorderStyle}">
                                    <TextBox Text="{Binding SelectedPerson.PresentAddress, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource PlainInputTextBox}"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                            <Button Content="Save Profile"
                                    Style="{StaticResource OutlineButton}"
                                    Command="{Binding OpenSaveConfirmCommand}"/>
                            <Button Content="Validate"
                                    Margin="12,0,0,0"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding OpenValidateModalCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ============================= -->
            <!-- VALIDATED SECTION             -->
            <!-- ============================= -->
            <Grid Grid.Row="2">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveMainTab}" Value="{x:Static vm:ValidatorsMainTab.Validated}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Search -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="360"/>
                                <ColumnDefinition Width="52"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource InputBorderStyle}">
                                <TextBox Text="{Binding SearchValidatedText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PlainInputTextBox}"/>
                            </Border>

                            <Button Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource IconButton}"
                                    Command="{Binding SearchValidatedCommand}">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE721;"
                                           FontSize="15"
                                           Foreground="White"/>
                            </Button>
                        </Grid>

                        <!-- Status pills -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,10">
                            <Button Content="Endorsed"
                                    Command="{Binding SetStatusTabCommand}"
                                    CommandParameter="{x:Static vm:ValidatorsStatusTab.Endorsed}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource StatusPill}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveStatusTab}" Value="{x:Static vm:ValidatorsStatusTab.Endorsed}">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="Pending"
                                    Margin="8,0,0,0"
                                    Command="{Binding SetStatusTabCommand}"
                                    CommandParameter="{x:Static vm:ValidatorsStatusTab.Pending}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource StatusPill}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveStatusTab}" Value="{x:Static vm:ValidatorsStatusTab.Pending}">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="Rejected"
                                    Margin="8,0,0,0"
                                    Command="{Binding SetStatusTabCommand}"
                                    CommandParameter="{x:Static vm:ValidatorsStatusTab.Rejected}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource StatusPill}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveStatusTab}" Value="{x:Static vm:ValidatorsStatusTab.Rejected}">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <!-- Found -->
                        <TextBlock Grid.Row="2"
                                   Text="{Binding ValidatedFoundText}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   Margin="2,0,0,10"/>

                        <!-- Table -->
                        <Border Grid.Row="3"
                                CornerRadius="18"
                                Background="White"
                                Padding="10"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1">
                            <DataGrid ItemsSource="{Binding ValidatedItems}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      RowHeaderWidth="0"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      FontSize="12"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      ColumnHeaderHeight="42"
                                      RowHeight="48"
                                      IsReadOnly="True"
                                      SelectionUnit="FullRow"
                                      SelectionMode="Single"
                                      FocusVisualStyle="{x:Null}">

                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLighter}"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="8,0"/>
                                    </Style>

                                    <Style TargetType="DataGridRow">
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLighter}"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FAFBFF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>

                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource CenteredCellStyle}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                    </Style>
                                </DataGrid.Resources>

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                    <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="*"/>
                                    <DataGridTextColumn Header="Last Name" Binding="{Binding LastName}" Width="*"/>
                                    <DataGridTextColumn Header="Gender" Binding="{Binding Gender}" Width="120"/>
                                    <DataGridTextColumn Header="Barangay" Binding="{Binding Barangay}" Width="140"/>
                                    <DataGridTextColumn Header="Classification" Binding="{Binding Classification}" Width="160"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>

                                    <DataGridTemplateColumn Width="110" Header="">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Button Style="{StaticResource RowActionButton}"
                                                            ToolTip="Edit Profile"
                                                            Command="{Binding DataContext.OpenProfileModalCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                   Text="&#xE70F;"
                                                                   FontSize="14"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    </Button>

                                                    <Button Style="{StaticResource RowActionButton}"
                                                            Margin="10,0,0,0"
                                                            ToolTip="Validate"
                                                            Command="{Binding DataContext.OpenValidateModalCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                   Text="&#xE73E;"
                                                                   FontSize="14"
                                                                   Foreground="{StaticResource AccentBrush}"/>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- VALIDATE MODAL -->
        <Grid Panel.ZIndex="920"
              Visibility="{Binding IsValidateModalOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#660F172A"/>
            <Button Style="{StaticResource BackdropButton}" Command="{Binding CloseValidateModalCommand}"/>

            <Border Width="520"
                    CornerRadius="24"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrushLighter}"
                    BorderThickness="1"
                    Padding="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{StaticResource ModalShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Validate"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                        <Button Grid.Column="1"
                                Style="{StaticResource OutlineButton}"
                                Width="34"
                                Height="34"
                                Padding="0"
                                Command="{Binding CloseValidateModalCommand}">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE8BB;"
                                       FontSize="12"/>
                        </Button>
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="0,16,0,0">
                        <TextBlock Text="Status" Style="{StaticResource FieldLabelText}"/>
                        <ComboBox Style="{StaticResource ModernComboBox}"
                                  ItemsSource="{Binding ValidateStatusOptions}"
                                  SelectedItem="{Binding ValidateSelectedStatus}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                        <Button Content="Cancel"
                                Width="120"
                                Height="40"
                                Style="{StaticResource OutlineButton}"
                                Command="{Binding CloseValidateModalCommand}"/>

                        <Button Content="Confirm"
                                Margin="14,0,0,0"
                                Width="140"
                                Height="40"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ConfirmValidateCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- PROFILE MODAL -->
        <Grid Panel.ZIndex="910"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              Visibility="{Binding IsProfileModalOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#660F172A"/>
            <Button Style="{StaticResource BackdropButton}" Command="{Binding CloseProfileModalCommand}"/>

            <Border Width="920"
                    CornerRadius="24"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrushLighter}"
                    BorderThickness="1"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                    Effect="{StaticResource ModalShadow}">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Profile Information"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                        <Button Grid.Column="1"
                                Style="{StaticResource OutlineButton}"
                                Width="34"
                                Height="34"
                                Padding="0"
                                Command="{Binding CloseProfileModalCommand}">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE8BB;"
                                       FontSize="12"/>
                        </Button>
                    </Grid>

                    <!-- Body -->
                    <ScrollViewer Grid.Row="1"
                                  Margin="0,18,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Avatar -->
                            <StackPanel Width="160" VerticalAlignment="Top">
                                <Grid Width="160" Height="160">
                                    <Ellipse Fill="#D9ECFF"/>

                                    <Ellipse>
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding SelectedPerson.ProfileImagePreview}"
                                                        Stretch="UniformToFill"/>
                                        </Ellipse.Fill>
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedPerson.HasProfileImage}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>

                                    <TextBlock Text="👤" FontSize="54" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedPerson.HasProfileImage}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <Button Content="Upload Photo"
                                        Margin="0,10,0,0"
                                        Style="{StaticResource SmallOutlineButton}"
                                        Command="{Binding UploadProfileImageCommand}"/>

                                <Button Content="Remove"
                                        Margin="0,8,0,0"
                                        Command="{Binding RemoveProfileImageCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SmallOutlineButton}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedPerson.HasProfileImage}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>

                            <!-- Form -->
                            <Grid Grid.Column="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0 -->
                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="Beneficiary ID" Style="{StaticResource FieldLabelText}"/>
                                    <Border Style="{StaticResource InputBorderStyle}">
                                        <TextBox Text="{Binding SelectedPerson.BeneficiaryId, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource PlainInputTextBox}"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <TextBlock Text="Civil Registry ID" Style="{StaticResource FieldLabelText}"/>
                                    <Border Style="{StaticResource InputBorderStyle}">
                                        <TextBox Text="{Binding SelectedPerson.CivilRegistryId, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource PlainInputTextBox}"/>
                                    </Border>
                                </StackPanel>

                                <!-- Row 1 -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,14,0,0">
                                    <TextBlock Text="First Name" Style="{StaticResource FieldLabelText}"/>
                                    <Border Style="{StaticResource InputBorderStyle}">
                                        <TextBox Text="{Binding SelectedPerson.FirstName, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource PlainInputTextBox}"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,14,0,0">
                                    <TextBlock Text="Middle Name" Style="{StaticResource FieldLabelText}"/>
                                    <Border Style="{StaticResource InputBorderStyle}">
                                        <TextBox Text="{Binding SelectedPerson.MiddleName, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource PlainInputTextBox}"/>
                                    </Border>
                                </StackPanel>

                                <!-- Row 2 -->
                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,14,0,0">
                                    <TextBlock Text="Gender" Style="{StaticResource FieldLabelText}"/>
                                    <ComboBox Style="{StaticResource ModernComboBox}"
                                              ItemsSource="{Binding GenderOptions}"
                                              SelectedItem="{Binding SelectedPerson.Gender, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,14,0,0">
                                    <TextBlock Text="Last Name" Style="{StaticResource FieldLabelText}"/>
                                    <Border Style="{StaticResource InputBorderStyle}">
                                        <TextBox Text="{Binding SelectedPerson.LastName, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource PlainInputTextBox}"/>
                                    </Border>
                                </StackPanel>

                                <!-- Row 3 -->
                                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,14,0,0">
                                    <TextBlock Text="Barangay" Style="{StaticResource FieldLabelText}"/>
                                    <Border Style="{StaticResource InputBorderStyle}">
                                        <TextBox Text="{Binding SelectedPerson.Barangay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource PlainInputTextBox}"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,14,0,0">
                                    <TextBlock Text="Classification" Style="{StaticResource FieldLabelText}"/>
                                    <ComboBox Style="{StaticResource ModernComboBox}"
                                              ItemsSource="{Binding ClassificationOptions}"
                                              SelectedItem="{Binding SelectedPerson.Classification, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <!-- Row 4 -->
                                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,14,0,0">
                                    <TextBlock Text="Present Address" Style="{StaticResource FieldLabelText}"/>
                                    <Border Style="{StaticResource InputBorderStyle}">
                                        <TextBox Text="{Binding SelectedPerson.PresentAddress, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource PlainInputTextBox}"/>
                                    </Border>
                                </StackPanel>

                                <!-- Release History -->
                                <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,22,0,0">
                                    <TextBlock Text="Release History"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="13"
                                               FontWeight="SemiBold"/>

                                    <Border Margin="0,10,0,0"
                                            Background="#F8FAFC"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="14">

                                        <Grid>
                                            <TextBlock Text="No releases yet."
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="12">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasReleaseHistory}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <ItemsControl ItemsSource="{Binding ReleaseHistory}">
                                                <ItemsControl.Style>
                                                    <Style TargetType="ItemsControl">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasReleaseHistory}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ItemsControl.Style>

                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,14">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="26"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Grid Grid.Column="0">
                                                                <Ellipse Width="10" Height="10"
                                                                         Fill="{StaticResource AccentBrush}"
                                                                         VerticalAlignment="Top"
                                                                         Margin="8,2,8,0"/>

                                                                <Border Width="2"
                                                                        Background="#E5ECFA"
                                                                        VerticalAlignment="Stretch"
                                                                        Margin="12,14,12,0">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsLast}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                </Border>
                                                            </Grid>

                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="{Binding ReleasedAtText}"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           FontWeight="SemiBold"/>

                                                                <TextBlock Text="{Binding Description}"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           FontSize="12"
                                                                           Margin="0,4,0,0"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </ScrollViewer>

                    <!-- Footer -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,18,0,0">
                        <Button Content="Save Profile"
                                Style="{StaticResource OutlineButton}"
                                Command="{Binding OpenSaveConfirmCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- SAVE PROFILE CONFIRM MODAL -->
        <Grid Panel.ZIndex="940"
              Visibility="{Binding IsSaveConfirmOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#660F172A"/>
            <Button Style="{StaticResource BackdropButton}" Command="{Binding CloseSaveConfirmCommand}"/>

            <Border Width="520"
                    CornerRadius="24"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrushLighter}"
                    BorderThickness="1"
                    Padding="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{StaticResource ModalShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Save Profile"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                        <Button Grid.Column="1"
                                Style="{StaticResource OutlineButton}"
                                Width="34"
                                Height="34"
                                Padding="0"
                                Command="{Binding CloseSaveConfirmCommand}">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE8BB;"
                                       FontSize="12"/>
                        </Button>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Text="Are you sure you want to save this profile?"
                               Margin="0,16,0,0"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap"/>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,18,0,0">
                        <Button Content="Cancel"
                                Width="140"
                                Height="40"
                                Style="{StaticResource OutlineButton}"
                                Command="{Binding CloseSaveConfirmCommand}"/>

                        <Button Content="Confirm"
                                Margin="14,0,0,0"
                                Width="160"
                                Height="40"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ConfirmSaveProfileCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>