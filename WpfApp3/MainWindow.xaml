<Window x:Class="WpfApp3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WpfApp3.ViewModels"
        Title="E-Kalinga Management System" Height="820" Width="1400"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Icon="/ekaling.png"
        Background="#F3F5F9">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="SidebarNavListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="SidebarNavListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5B52EF"/>
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#2E3A59"/>
                                <Setter TargetName="Bd" Property="Background" Value="White"/>
                            </Trigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Foreground" Value="#2E3A59"/>
                                <Setter TargetName="Bd" Property="Background" Value="White"/>
                            </MultiTrigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarLogoutButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        CornerRadius="12"
                        Padding="{TemplateBinding Padding}"
                        SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5B52EF"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4338CA"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#1F2A44">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <!-- Logo / Title -->
                <StackPanel Grid.Row="0"
            Margin="20"
            VerticalAlignment="Center"
            Orientation="Horizontal">

                    <Image Source="/Ekalinga-Icon.png"
           Width="60"
           Height="60"
           Margin="0,0,14,0"
           Stretch="Uniform"
           VerticalAlignment="Center"/>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="E-Kalinga"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="White"/>
                        <TextBlock Text="Management System"
                   FontSize="12"
                   Foreground="White"/>
                    </StackPanel>
                </StackPanel>

                <!-- Menu -->
                <ListBox Grid.Row="1"
                         Style="{StaticResource SidebarNavListBoxStyle}"
                         ItemContainerStyle="{StaticResource SidebarNavListBoxItemStyle}"
                         ItemsSource="{Binding NavItems}"
                         SelectedItem="{Binding SelectedNavItem}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}"
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Grid.Row="2"
        Margin="12,0,12,18"
        Padding="16,12"
        Background="Transparent"
        BorderBrush="Transparent"
        Foreground="White"
        HorizontalAlignment="Stretch"
        HorizontalContentAlignment="Left"
        Command="{Binding LogoutCommand}"
        Style="{StaticResource SidebarLogoutButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⎋"
                   FontSize="15"
                   Margin="0,0,10,0"
                   VerticalAlignment="Center"/>
                        <TextBlock Text="Log Out"
                   FontSize="14"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Grid Grid.Row="0" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding PageTitle}"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="#2E3A59"
                           VerticalAlignment="Center"/>

                <Border Grid.Column="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Grid Width="42"
                              Height="42"
                              Margin="0,0,10,0">
                            <Ellipse Fill="#E9EEF7"/>

                            <Image Source="{Binding CurrentUserProfileImage}"
                                   Stretch="UniformToFill">
                                <Image.Clip>
                                    <EllipseGeometry Center="21,21"
                                                     RadiusX="21"
                                                     RadiusY="21"/>
                                </Image.Clip>
                            </Image>

                            <TextBlock Text="👤"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsCurrentUserProfileImageEmpty, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Page host -->
            <Border Grid.Row="1">
                <ContentControl Content="{Binding CurrentView}" />
            </Border>
        </Grid>
    </Grid>
</Window>